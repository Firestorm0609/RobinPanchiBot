TELEGRAM_BOT_TOKEN=your_telegram_bot_token
RPC_URL=https://robinhood-mainnet.g.alchemy.com/v2/your_alchemy_key
CHAIN_ID=4663
ZEROX_API_KEY=your_0x_api_key
AFFILIATE_ADDRESS=0xYourFeeCollectorAddress
AFFILIATE_FEE_BPS=50

# 32-byte hex key used to encrypt wallet private keys at rest.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
MASTER_KEY=your_64_char_hex_master_key

# Your own Telegram user/chat ID — receives admin alerts (failed trades,
# stuck trades/bridges after restart, crashes) and unlocks /admin_stats.
ADMIN_CHAT_ID=your_telegram_chat_id

# Required for the bridge feature to be production-ready:
# - ETH_RPC_URL: Ethereum mainnet RPC (Alchemy/Infura). Without this it falls
#   back to a public endpoint (cloudflare-eth.com), which is unreliable at volume.
# - EXPLORER_BASE_URL: block explorer base URL for Robinhood Chain tx links,
#   e.g. https://explorer.robinhood-chain.example (no trailing slash).
ETH_RPC_URL=https://eth-mainnet.g.alchemy.com/v2/your_alchemy_key
EXPLORER_BASE_URL=https://explorer.robinhood-chain.example

# Passphrase used by backup.sh to GPG-encrypt SQLite backups.
# Long random string, NOT the same as MASTER_KEY.
BACKUP_PASSPHRASE=your_long_random_backup_passphrase
